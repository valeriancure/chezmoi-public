#!/bin/sh
set -eu

tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/terminal-clipboard-image.XXXXXX")
trap 'rm -rf "$tmpdir"' EXIT INT TERM

image=$tmpdir/clipboard.png

command -v kitten >/dev/null 2>&1 || {
  echo "terminal-send-clipboard-image: kitten is required" >&2
  exit 1
}

command -v terminal-send-file >/dev/null 2>&1 || {
  echo "terminal-send-clipboard-image: terminal-send-file is required" >&2
  exit 1
}

kitten clipboard -g "$image"
terminal-send-file --name clipboard.png --mime image/png "$image"
