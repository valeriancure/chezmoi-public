#!/bin/sh
set -eu

usage() {
  echo "usage: terminal-send-file [--name NAME] [--mime MIME] FILE" >&2
  exit 2
}

quote_meta() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/^/"/; s/$/"/'
}

name=
mime=

while [ "$#" -gt 0 ]; do
  case "$1" in
    --name)
      [ "$#" -ge 2 ] || usage
      name=$2
      shift 2
      ;;
    --mime)
      [ "$#" -ge 2 ] || usage
      mime=$2
      shift 2
      ;;
    --help|-h)
      usage
      ;;
    --)
      shift
      break
      ;;
    -*)
      usage
      ;;
    *)
      break
      ;;
  esac
done

[ "$#" -eq 1 ] || usage
file=$1
[ -f "$file" ] || {
  echo "terminal-send-file: not a regular file: $file" >&2
  exit 1
}

command -v kitten >/dev/null 2>&1 || {
  echo "terminal-send-file: kitten is required" >&2
  exit 1
}

[ -n "$name" ] || name=${file##*/}
if [ -z "$mime" ]; then
  mime=$(file --brief --mime-type "$file" 2>/dev/null || printf 'application/octet-stream')
fi
size=$(wc -c < "$file" | tr -d ' ')

{
  printf '__TERMINAL_FILE_BEGIN__ name=%s mime=%s size=%s\n' \
    "$(quote_meta "$name")" \
    "$(quote_meta "$mime")" \
    "$size"
  base64 "$file"
  printf '\n__TERMINAL_FILE_END__\n'
} | kitten @ send-text --stdin --bracketed-paste=disable
